{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "edge-muse",
  "main": "src/index.ts",
  "workers_dev": true,
  "preview_urls": false,
  // Fill your production hostname, then uncomment this block before deploying.
  "routes": [
    {
      "pattern": "pinkteck.com",
      "custom_domain": true
    },
    {
      "pattern": "www.pinkteck.com",
      "custom_domain": true
    }
  ],
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/ws/*"]
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": false
    },
    "traces": {
      "enabled": false
    }
  },
  "triggers": {
    "crons": ["17 18 * * *"]
  },
  "vars": {
    "ENVIRONMENT": "production",
    "AI_GATEWAY_ID": "default",
    "AI_GATEWAY_URL": "",
    "PROMPT_ASSISTANT_ENABLED": "true",
    "PROMPT_ASSISTANT_MODEL": "@cf/qwen/qwen3-30b-a3b-fp8",
    "ASSETS_PUBLIC_BASE_URL": "https://assets.pinkteck.com",
    "CAPTCHA_DOMESTIC_PROVIDER": "tencent",
    "CAPTCHA_OVERSEAS_PROVIDER": "turnstile",
    "ALTCHA_DEFAULT_DIFFICULTY": "50000",
    "TENCENT_CAPTCHA_APP_ID": "",
    "TENCENTCLOUD_CAPTCHA_REGION": "ap-guangzhou",
    "TURNSTILE_SITE_KEY": "0x4AAAAAADDgU0ueTVgP8AUe",
    "ALERT_EMAIL": ""
  },
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "edge-muse",
      "database_id": "5fca4c29-a54c-4b7c-a3bd-f94bcd156a4a"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "edge-muse-images"
    },
    {
      "binding": "ASSETS_R2",
      "bucket_name": "edge-muse-assets"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "ac7b33570100436fa033d09422daf050"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "TASK_ROOM",
        "class_name": "TaskRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TaskRoom"]
    }
  ],
  "workflows": [
    {
      "name": "GenerateImage",
      "binding": "GEN_WORKFLOW",
      "class_name": "GenerateImageWorkflow"
    }
  ]
}
